# === Production Environment Variables ===
# Copy this to .env and fill in real values before deploying

# Django
SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(50))">
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Main PostgreSQL
DB_NAME=sql_learning
DB_USER=postgres
DB_PASSWORD=<strong-random-password>

# CORS — your frontend domain
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Frontend build-time API URL (baked into JS bundle)
VITE_API_URL=https://your-domain.com

# MariaDB sandbox root password
MARIADB_ROOT_PASSWORD=<strong-random-password>

# Gemini API key for AI dataset generation (get one at https://aistudio.google.com/app/apikey)
# Leave empty to disable the "Generate with AI" feature.
GEMINI_API_KEY=

# HTTPS hardening (set True only if nginx is serving HTTPS with a valid cert)
ENABLE_HTTPS=False
